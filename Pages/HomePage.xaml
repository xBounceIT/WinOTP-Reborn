<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinOTP.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinOTP.Models">

    <Page.Resources>
        <x:Double x:Key="CardColumnWidth">360</x:Double>
    </Page.Resources>

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Search, Sort and Add controls -->
        <Grid Grid.Row="0"
              Margin="4,0,4,8"
              Width="{StaticResource CardColumnWidth}"
              HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search bar -->
            <AutoSuggestBox x:Name="SearchBox"
                            Grid.Column="0"
                            PlaceholderText="Search accounts..."
                            QueryIcon="Find"
                            TextChanged="SearchBox_TextChanged"
                            QuerySubmitted="SearchBox_QuerySubmitted"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            MinHeight="30"/>

            <!-- Sort and Add buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <DropDownButton ToolTipService.ToolTip="Sort accounts" MinHeight="32">
                    <FontIcon Glyph="&#xE8CB;" FontSize="14"/>
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                            <RadioMenuFlyoutItem x:Name="SortNewestFirst" Text="Date Added (Newest)" GroupName="SortGroup" Click="SortMenuItem_Click" Tag="DateAddedDesc"/>
                            <RadioMenuFlyoutItem x:Name="SortOldestFirst" Text="Date Added (Oldest)" GroupName="SortGroup" Click="SortMenuItem_Click" Tag="DateAddedAsc"/>
                            <RadioMenuFlyoutItem x:Name="SortNameAsc" Text="Name (A → Z)" GroupName="SortGroup" Click="SortMenuItem_Click" Tag="AlphabeticalAsc"/>
                            <RadioMenuFlyoutItem x:Name="SortNameDesc" Text="Name (Z → A)" GroupName="SortGroup" Click="SortMenuItem_Click" Tag="AlphabeticalDesc"/>
                            <RadioMenuFlyoutItem x:Name="SortCustomOrder" Text="Custom order" GroupName="SortGroup" Click="SortMenuItem_Click" Tag="CustomOrder"/>
                            <RadioMenuFlyoutItem x:Name="SortUsageBased" Text="Most used" GroupName="SortGroup" Click="SortMenuItem_Click" Tag="UsageBased"/>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
                <Button x:Name="AddButton" Click="AddButton_Click" ToolTipService.ToolTip="Add account" MinHeight="32">
                    <FontIcon Glyph="&#xE710;" FontSize="14"/>
                </Button>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Spacing="8" Margin="0,0,0,8">
            <InfoBar
                x:Name="LoadIssuesInfoBar"
                IsOpen="False"
                IsClosable="True"
                Severity="Warning"
                Title="Some accounts were skipped" />
            <InfoBar
                x:Name="OperationInfoBar"
                IsOpen="False"
                IsClosable="True"
                Severity="Error"
                Title="Operation failed" />
        </StackPanel>

        <!-- Account list -->
        <GridView x:Name="OtpGridView"
                  Grid.Row="2"
                  SelectionMode="None"
                  HorizontalContentAlignment="Left"
                  Padding="4,0,4,0"
                  AllowDrop="False"
                  CanDragItems="False"
                  CanReorderItems="False">
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,4,0,4"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid x:Name="OtpItemsWrapGrid"
                                   Orientation="Horizontal"
                                   MaximumRowsOrColumns="1"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="local:OtpAccount">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8"
                            Width="{StaticResource CardColumnWidth}"
                            MinHeight="140">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel x:Name="ReorderControlsPanel"
                                        Grid.Column="0"
                                        Width="40"
                                        MinWidth="40"
                                        Margin="4,8,0,8"
                                        Orientation="Vertical"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed"
                                        Spacing="4">
                                <Border x:Name="ReorderHandle"
                                        Width="32"
                                        Height="32"
                                        Background="Transparent"
                                        CornerRadius="8"
                                        Tag="{x:Bind Id}"
                                        PointerEntered="ReorderHandle_PointerEntered"
                                        PointerExited="ReorderHandle_PointerExited"
                                        PointerPressed="ReorderHandle_PointerPressed"
                                        PointerReleased="ReorderHandle_PointerReleased"
                                        PointerCanceled="ReorderHandle_PointerReleased"
                                        ToolTipService.ToolTip="Drag to reorder"
                                        AutomationProperties.Name="Drag to reorder">
                                    <Grid Width="14"
                                          Height="14"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="2.5" Height="2.5" Fill="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Ellipse Grid.Column="1" Width="2.5" Height="2.5" Fill="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Ellipse Grid.Column="2" Width="2.5" Height="2.5" Fill="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Ellipse Grid.Row="1" Width="2.5" Height="2.5" Fill="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Ellipse Grid.Row="1" Grid.Column="1" Width="2.5" Height="2.5" Fill="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Ellipse Grid.Row="1" Grid.Column="2" Width="2.5" Height="2.5" Fill="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Ellipse Grid.Row="2" Width="2.5" Height="2.5" Fill="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Ellipse Grid.Row="2" Grid.Column="1" Width="2.5" Height="2.5" Fill="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Ellipse Grid.Row="2" Grid.Column="2" Width="2.5" Height="2.5" Fill="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <Grid Grid.Column="1" Padding="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 0: Account info and action buttons -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Account label -->
                                <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
                                    <TextBlock Text="{x:Bind IssuerOrAccountName}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"/>
                                    <TextBlock Text="{x:Bind SecondaryLabel}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"/>
                                </StackPanel>

                                <!-- Action buttons -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Top">
                                    <Button Background="Transparent"
                                            BorderBrush="Transparent"
                                            Padding="8,4"
                                            MinWidth="0"
                                            Click="CopyButton_Click"
                                            Tag="{x:Bind Id}"
                                            ToolTipService.ToolTip="Copy TOTP code">
                                        <FontIcon x:Name="CopyButtonIcon" Glyph="&#xE8C8;" FontSize="14"/>
                                    </Button>
                                    <Button Background="Transparent"
                                            BorderBrush="Transparent"
                                            Padding="8,4"
                                            MinWidth="0"
                                            Click="EditButton_Click"
                                            Tag="{x:Bind Id}"
                                            ToolTipService.ToolTip="Edit account">
                                        <FontIcon Glyph="&#xE70F;" FontSize="14"/>
                                    </Button>
                                    <Button Background="Transparent"
                                            BorderBrush="Transparent"
                                            Padding="8,4"
                                            MinWidth="0"
                                            Click="DeleteButton_Click"
                                            Tag="{x:Bind Id}"
                                            ToolTipService.ToolTip="Delete account">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- TOTP code and next code -->
                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        Margin="0,8,0,0">
                                <TextBlock x:Name="CodeTextBlock"
                                           Style="{StaticResource TitleTextBlockStyle}"
                                           FontSize="28"
                                           FontFamily="Consolas"
                                           VerticalAlignment="Center"/>

                                <TextBlock x:Name="NextCodeTextBlock"
                                           FontSize="16"
                                           FontFamily="Consolas"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           Opacity="0"/>
                            </StackPanel>

                            <!-- Progress bar and timer -->
                            <Grid Grid.Row="3"
                                  ColumnSpacing="8" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <!-- Custom progress bar (avoids WinUI3 animation bug) -->
                                <Grid Grid.Column="0" Height="4" VerticalAlignment="Center">
                                    <Rectangle Fill="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch"
                                               RadiusX="2" RadiusY="2"/>
                                    <Rectangle x:Name="ProgressBarFill"
                                               Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Stretch"
                                               RadiusX="2" RadiusY="2"
                                               Width="0"/>
                                </Grid>
                                <TextBlock Grid.Column="1"
                                           x:Name="RemainingTextBlock"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Opacity="0.7"/>
                            </Grid>
                        </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <!-- Empty state -->
        <StackPanel
            x:Name="EmptyStatePanel"
            Grid.Row="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="8">
            <FontIcon
                Glyph="&#xE8D7;"
                FontSize="48"
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock
                Text="No OTP entries yet"
                Style="{StaticResource SubtitleTextBlockStyle}"
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock
                Text="Click Add Account to get started"
                Style="{StaticResource BodyTextBlockStyle}"
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
        </StackPanel>
    </Grid>

</Page>
